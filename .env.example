# Environment Variables Example

# This file contains example environment variables.
# Copy this file to .env.local and fill in your values.

# ============================================
# Application Settings
# ============================================

# Application Name
VITE_APP_NAME=CryptP

# Application Version
VITE_APP_VERSION=1.0.0

# ============================================
# Blockchain Settings
# ============================================

# Default RPC Provider (optional)
# Used for reading blockchain data if needed
VITE_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Infura Project ID (optional)
# Get from https://infura.io
VITE_INFURA_PROJECT_ID=

# Etherscan API Key (optional)
# Used for contract verification
# Get from https://etherscan.io/apis
VITE_ETHERSCAN_API_KEY=

# ============================================
# Network Configuration
# ============================================

# Default Network
# Options: sepolia, goerli, mainnet
VITE_DEFAULT_NETWORK=sepolia

# ============================================
# Feature Flags
# ============================================

# Enable development features
VITE_DEBUG_MODE=false

# Enable experimental features
VITE_EXPERIMENTAL_FEATURES=false

# ============================================
# Build Settings
# ============================================

# Build mode
NODE_ENV=development

# Source maps for debugging
VITE_SOURCE_MAP=true

# ============================================
# Notes
# ============================================

# - Do NOT commit .env.local to version control
# - Keep sensitive keys private
# - Use different keys for development, staging, and production
# - Rotate keys regularly
# - Never share API keys in public repositories
